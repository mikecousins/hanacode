---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Contact | Hana Code Corp"
  description="Get in touch with Hana Code Corp. App support, business inquiries, and more."
>
  <Header />
  <main>
    <section class="section hero">
      <h1>Contact Us</h1>
    </section>
    <section class="section">
      <div class="card">
        <h2>Get in Touch</h2>
        <p>
          We'd love to hear from you. Whether you have a question about one of
          our apps, need support, or want to discuss a business opportunity,
          here's how to reach us.
        </p>
        <div class="contact-details">
          <div class="contact-item">
            <h3>Email</h3>
            <p><a href="mailto:hana@cousins.ai">hana@cousins.ai</a></p>
          </div>
          <div class="contact-item">
            <h3>Location</h3>
            <p>Calgary, Alberta, Canada</p>
          </div>
        </div>
      </div>

      <div class="card">
        <h2>App Support</h2>
        <p>
          Need help with Slackwater or one of our other apps? We're here to
          help. When reaching out for support, please include:
        </p>
        <ul>
          <li>The name of the app you need help with</li>
          <li>Your device model (e.g., iPhone 16, iPad Pro)</li>
          <li>Your iOS or operating system version</li>
          <li>A description of the issue you're experiencing</li>
        </ul>
        <p>
          Email us at
          <a href="mailto:hana@cousins.ai?subject=App%20Support">hana@cousins.ai</a>
          with the subject line "App Support" and we'll get back to you as
          quickly as possible.
        </p>
      </div>

      <div class="card">
        <h2>Feature Requests & Feedback</h2>
        <p>
          Have an idea for a feature or want to share feedback about one of our
          apps? We genuinely read every message and use your feedback to guide
          our development priorities. Send your thoughts to
          <a href="mailto:hana@cousins.ai?subject=Feedback">hana@cousins.ai</a>.
        </p>
      </div>

      <div class="card">
        <h2>Business Inquiries</h2>
        <p>
          For partnerships, press inquiries, or other business matters, please
          reach out at
          <a href="mailto:hana@cousins.ai?subject=Business%20Inquiry">hana@cousins.ai</a>.
        </p>
      </div>

      <div class="card">
        <h2>Company Information</h2>
        <p>
          <strong>Hana Code Corp</strong><br />
          Calgary, Alberta, Canada<br />
          <a href="mailto:hana@cousins.ai">hana@cousins.ai</a>
        </p>
        <p>Incorporated in Canada.</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  h1 {
    font-size: 4rem;
    text-transform: uppercase;
    line-height: 1;
  }

  h2 {
    font-size: 1.5rem;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h3 {
    font-size: 1.1rem;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  p {
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  p:last-child {
    margin-bottom: 0;
  }

  ul {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  li {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .card {
    margin-bottom: 2rem;
  }

  .card:last-child {
    margin-bottom: 0;
  }

  .contact-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .contact-item {
    border-left: 4px solid var(--color-border);
    padding-left: 1rem;
  }

  .contact-item p {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 4rem;
      padding-bottom: 2rem;
    }

    h1 {
      font-size: 2.5rem;
    }

    .contact-details {
      grid-template-columns: 1fr;
    }
  }
</style>
