---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Projects | Hana Code Corp"
  description="Projects built by Hana Code Corp."
>
  <Header />
  <main>
    <section class="section hero">
      <h1>Projects</h1>
    </section>
    <section class="section">
      <div class="card project-card">
        <h2>Slackwater</h2>
        <p class="tagline">Retirement planning for Canadians.</p>
        <p>
          Slackwater helps Canadians find financial clarity by modeling
          retirement timelines and optimizing withdrawal strategies across
          RRSP, TFSA, and non-registered accounts. See when you can retire
          and how to make your money last.
        </p>
      </div>

      <div class="card">
        <h2>The Problem</h2>
        <p>
          Canadian retirement planning is complex. The order in which you
          withdraw from RRSP, TFSA, and non-registered accounts dramatically
          affects your lifetime tax burden. CPP and OAS timing decisions can
          mean tens of thousands of dollars in difference. And most retirement
          calculators are built for the American market — they don't understand
          Canadian registered accounts, our tax brackets, or our government
          benefit programs.
        </p>
        <p>
          Canadians deserve a retirement planning tool that speaks their
          financial language.
        </p>
      </div>

      <div class="card">
        <h2>The Solution</h2>
        <p>
          Slackwater models your complete Canadian financial picture. It
          optimizes withdrawal strategies across all your account types,
          projects CPP and OAS benefits based on your chosen start dates, and
          shows year-by-year retirement timelines so you can see exactly when
          your money runs out — or doesn't.
        </p>
        <p>
          Every calculation is built specifically for Canadian tax rules,
          contribution limits, and benefit programs. No American assumptions,
          no generic rules of thumb.
        </p>
      </div>

      <div class="card">
        <h2>Key Features</h2>
        <div class="features">
          <div class="feature">
            <h3>Withdrawal Optimization</h3>
            <p>
              Smart strategies across registered and non-registered accounts
              to minimize taxes and maximize income throughout retirement.
            </p>
          </div>
          <div class="feature">
            <h3>Retirement Timeline</h3>
            <p>
              See when you can retire based on your actual financial picture,
              not generic rules of thumb.
            </p>
          </div>
          <div class="feature">
            <h3>CPP & OAS Modeling</h3>
            <p>
              Project your Canada Pension Plan and Old Age Security benefits.
              See how delaying or starting early affects your total retirement
              income.
            </p>
          </div>
          <div class="feature">
            <h3>Tax Projection</h3>
            <p>
              Year-by-year tax estimates using current federal and provincial
              brackets, including OAS clawback thresholds and dividend tax
              credits.
            </p>
          </div>
          <div class="feature">
            <h3>Scenario Comparison</h3>
            <p>
              Compare different retirement scenarios side by side. See how
              changes to your retirement age, spending, or investment returns
              affect your outcome.
            </p>
          </div>
          <div class="feature">
            <h3>Canadian-Focused</h3>
            <p>
              Built specifically for Canadian tax rules, CPP, OAS, RRSP, TFSA,
              and non-registered account types.
            </p>
          </div>
        </div>
      </div>

      <div class="card">
        <h2>Available On</h2>
        <p>
          Slackwater is available on the web. An iOS app is coming soon to the
          Apple App Store.
        </p>
        <a
          href="https://www.slackwater.ca"
          class="btn"
          target="_blank"
          rel="noopener"
        >
          Visit Slackwater
        </a>
      </div>
    </section>

    <section class="section">
      <div class="card coming-soon">
        <h2>More Projects</h2>
        <p>
          We're actively developing new applications. Our focus remains on
          building thoughtful, well-crafted tools that help Canadians with
          financial planning and everyday productivity. Stay tuned.
        </p>
        <a href="/contact" class="btn btn-secondary">Get in Touch</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  h1 {
    font-size: 4rem;
    text-transform: uppercase;
    line-height: 1;
  }

  h2 {
    font-size: 2rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-accent);
  }

  .card {
    margin-bottom: 2rem;
  }

  .card:last-child {
    margin-bottom: 0;
  }

  .project-card p {
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .feature {
    border-left: 4px solid var(--color-border);
    padding-left: 1rem;
  }

  .feature h3 {
    font-size: 1.1rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .feature p {
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  .btn-secondary {
    background: var(--color-card-bg);
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 4rem;
      padding-bottom: 2rem;
    }

    h1 {
      font-size: 2.5rem;
    }
  }
</style>
